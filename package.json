{
  "name": "coach-titan-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "./node_modules/.bin/vite",
    "build": "./node_modules/.bin/vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "ios:preflight": "bash ./scripts/ios-preflight.sh",
    "cap:sync": "npm run build && ./node_modules/.bin/cap sync ios",
    "cap:open": "./node_modules/.bin/cap open ios",
    "ios": "npm run ios:preflight && npm run cap:sync && npm run cap:open",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@capacitor/core": "^8.0.1",
    "@capacitor/ios": "^8.0.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.1",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "tar": "^7.5.4"
  }
}
